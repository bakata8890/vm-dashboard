# Copia este archivo a .env y completa los valores reales.
# NUNCA commitear .env con valores reales.

# BFF
JWT_SECRET=changeme-min-32-chars-in-local
INTERNAL_PROXY_SECRET=changeme-shared-bff-apicore

# API Core
# (INTERNAL_PROXY_SECRET también aplica aquí — mismo valor que BFF)

# Base de datos (compartida entre servicios en Docker Compose)
DATABASE_URL=postgres://changeme-db-user:changeme-db-pass@localhost:5433/vm_db?sslmode=disable

# Entorno: "dev" | "prod"  (prod activa Secure en la cookie)
APP_ENV=dev

# URL interna del api-core (solo relevante para el BFF)
API_CORE_URL=http://localhost:8080
